# APIキー等の秘匿情報（このファイルを .env にコピーして記入）
# 必須ではないキーは空のままでOK（該当サイトが自動でスキップされます）

# --- Phase 1: 無料登録のみで使える ---
# 楽天デベロッパー: https://webservice.rakuten.co.jp/
# 新認証方式: アプリケーションID（UUID形式）とアクセスキー（pk_...）の両方が必要。
# さらにアプリ編集画面の「許可されたWebサイト」に実行元のグローバルIPを
# CIDR形式（例: 203.0.113.5/32）で登録すること（IPが変わったら更新）
RAKUTEN_APP_ID=
RAKUTEN_ACCESS_KEY=
# Yahoo!デベロッパー: https://e.developer.yahoo.co.jp/
YAHOO_APP_ID=

# --- Phase 3: 海外仕入れ・Amazon ---
# Amazon PA-API v5（アソシエイト登録＋売上実績が必要）
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
# eBay Developer: https://developer.ebay.com/
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# AliExpressアフィリエイト: https://portals.aliexpress.com/
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
ALIEXPRESS_TRACKING_ID=

# --- Google Sheets出力（サービスアカウントのJSONパス） ---
GOOGLE_SHEETS_CREDENTIALS=credentials.json
